def factors num {
  let list = []
  let candidate = 2
  let max = math::sqrt num
  while candidate <= max {
    list.push candidate if num %% candidate
    candidate = candidate + 1
  }
  list
}

def prime? num {
  factors(num).length == 0
}

factors 600851475143
  | _.filter(prime?)
  | _.reduce(0, math::max)
  | println
