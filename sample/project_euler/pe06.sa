def sum list {
  let acc = 0
  list.each => elem {
    acc = acc + elem
  }
  acc
}

def square num {
  num * num
}

def map f {
  => l { l.map(f) }
}

def sum_squares list {
  list | (square | map) | sum
}

def square_sum list {
  list | sum | square
}

...[1, 101] | list::iota | (square_sum _) - (sum_squares _) | println
