def is_palindrome num {
  let string_num = num | string::from
  string_num == string_num.split().reverse().join()
}

let max = 0

let a = 999
while a >= 100 {
  let b = 999
  while b >= 100 {
    let product = a * b
    max = product if product > max and is_palindrome product
    b = b - 1
  }
  a = a - 1
}

println max
